# Copy this file to .env and fill in values

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-long-random-string

# Google Sheets spreadsheet ID (from the URL)
SPREADSHEET_ID=your-spreadsheet-id-here

# Google service account credentials as a JSON string (for Railway/cloud)
# Alternatively, set up config/google-service-account.json locally
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Gmail OAuth2 (advancing email integration) ────────────────────────────────
# See scripts/setup-gmail-oauth.js for step-by-step instructions.
GMAIL_USER=productionwindjammer@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Set to production when deploying
NODE_ENV=development

# Public URL where the app is hosted (used in onboarding invite emails).
# Optional — if unset, the server uses RAILWAY_PUBLIC_DOMAIN or the request host.
PUBLIC_APP_URL=https://your-app.up.railway.app

# Gmail OAuth callback URL (must match what's registered in Google Cloud Console).
# Locally: http://localhost:3001/api/gmail/callback
# Railway: https://your-app.up.railway.app/api/gmail/callback
OAUTH_REDIRECT_URI=https://your-app.up.railway.app/api/gmail/callback
